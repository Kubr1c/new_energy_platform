#######################################
# OpenCode Backend Environment Example
#######################################

# 连接数据库的 URL，格式示例：
# mysql+pymysql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>/<DB_NAME>
DATABASE_URL=mysql+pymysql://root:123456@localhost/energy_db

# 用于 Flask 的安全密钥，生产环境请改为强随机值
SECRET_KEY=change-me-in-production

# 其他需要的环境变量可以在此扩展
